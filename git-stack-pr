#!/bin/bash
# git-stack-pr: create a PR for the bottom branch of the stack
set -e

MAIN_BRANCH=$(git config init.defaultBranch 2>/dev/null || echo "main")

if [ -z "$1" ]; then
    echo "Usage: git stack-pr <title>"
    exit 1
fi

TITLE="$1"
BRANCH=$(git branch --show-current)

if [ -z "$BRANCH" ] || [ "$BRANCH" = "$MAIN_BRANCH" ]; then
    echo "Error: not on a stack branch."
    exit 1
fi

PARENT=$(git config "branch.$BRANCH.stack-parent" 2>/dev/null || echo "")
if [ -z "$PARENT" ]; then
    echo "Error: branch '$BRANCH' is not part of a stack."
    exit 1
fi

# walk down to the bottom of the stack
BOTTOM="$BRANCH"
while true; do
    PARENT=$(git config "branch.$BOTTOM.stack-parent" 2>/dev/null || echo "")
    BASE="${PARENT#origin/}"
    if [ "$BASE" = "$MAIN_BRANCH" ]; then
        break
    fi
    BOTTOM="$PARENT"
done

# push the bottom branch without checking it out
git push origin "$BOTTOM" --force-with-lease >/dev/null 2>&1 || \
    git push origin "$BOTTOM" >/dev/null 2>&1

# create the PR targeting main
gh pr create --head "$BOTTOM" --base "$MAIN_BRANCH" --title "$TITLE" --body ""
